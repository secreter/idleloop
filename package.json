{
  "name": "idleloop",
  "version": "0.0.0",
  "description": "Use your soon-to-reset Claude Max quota while you sleep. AI does the work in isolated worktrees, you review in the morning.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "idleloop": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "pino": "^9.5.0",
    "simple-git": "^3.27.0",
    "ulid": "^2.3.0",
    "undici": "^8.2.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.5",
    "eslint": "^9.15.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/secreter/idleloop.git"
  },
  "homepage": "https://github.com/secreter/idleloop",
  "bugs": {
    "url": "https://github.com/secreter/idleloop/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "automation",
    "cli",
    "worktree",
    "quota",
    "ai-native"
  ],
  "license": "MIT",
  "author": "secreter"
}
